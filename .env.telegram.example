# ─────────────────────────────────────────────────────────────────────────────
# Hermes Agent — Telegram Bot Environment Variables (EXAMPLE)
#
# Copy this file to .env and fill in your actual values.
# NEVER commit .env or your real bot token to version control.
#
# Get a bot token: https://t.me/BotFather → /newbot
# Get your user ID: https://t.me/userinfobot → /start
# Get an OpenRouter key: https://openrouter.ai/keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIjklmnopqrstuvwxyz_EXAMPLE

# Your Telegram user ID (numeric — from @userinfobot)
TELEGRAM_ADMIN_USER_ID=123456789

# OpenRouter API key for model access
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ── Optional — Access Control ─────────────────────────────────────────────────

# Comma-separated additional user IDs allowed to use the bot
# (The admin user is always allowed regardless of this list)
# TELEGRAM_ALLOWED_USERS=111111111,222222222

# Allow ALL Telegram users (default: false — deny unless listed above)
# Only set to true if you want a fully public bot.
# GATEWAY_ALLOW_ALL_USERS=false

# ── Optional — Webhook (for production deployments) ───────────────────────────

# When set, the bot switches from long-polling to webhook mode.
# Leave unset to use long-polling (simpler for local development).
# TELEGRAM_WEBHOOK_URL=https://your-app.up.railway.app

# Webhook listening port (default: 8443)
# TELEGRAM_WEBHOOK_PORT=8443

# Recommended: set a random secret so only Telegram can POST to your webhook.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# TELEGRAM_WEBHOOK_SECRET=your-random-secret-here

# ── Optional — Model Selection ────────────────────────────────────────────────

# Hermes default model (override the system default)
# HERMES_DEFAULT_MODEL=anthropic/claude-3.5-sonnet

# ── Optional — Rate Limiting ──────────────────────────────────────────────────

# Maximum messages per minute per user (default: 30)
# TELEGRAM_RATE_LIMIT_PER_MINUTE=30

# ── Optional — Timeouts ───────────────────────────────────────────────────────

# Telegram API request timeout in seconds (default: 30)
# TELEGRAM_REQUEST_TIMEOUT=30

# Maximum seconds the agent is allowed to run per request (default: 300)
# TELEGRAM_AGENT_TIMEOUT=300

# ── Optional — Session Storage ────────────────────────────────────────────────

# Path to SQLite session database (default: telegram_sessions.db)
# TELEGRAM_SESSION_DB=telegram_sessions.db
